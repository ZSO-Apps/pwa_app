# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
data/.session-secret
data/users.yaml
data/forms/
data/appell/
data/transport/

# Appell source spreadsheets (contain real personal data: names, AHV, phone)
Appellliste*.xlsx
Appellliste*.xlsx:Zone.Identifier

# Environment
.env
.env.local
.env.*.local

# Build output
dist/
build/
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Cache
.cache/
.npm/
.parcel-cache/

# Per-org public folder is a generated symlink to ZSO/<Org> (see server/org.js)
content_zso_specific_public

# Organisation-specific logos (local tenant branding). The ZSO/ folders are the
# tracked source of truth; per-org branding logos stay local, the fallback logo
# and READMEs are tracked.
ZSO/*/logos/org_logo_*.png
ZSO/*/logos/*.png:Zone.Identifier
